{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "idForm": {
      "type": "integer",
      "const": 4
    },
    "name": {
      "type": "string",
      "const": "errorsInformation"
    },
    "hash": { "type": "string" },
    "taskName": { "type": "string" },
    "dateTime": { "type": "string", "format": "date-time" },
    "cancellable": { "type": "string" },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" },
          "level": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "required": []
}
